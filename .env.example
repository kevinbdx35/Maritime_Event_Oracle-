# ─── AIS data sources ───────────────────────────────────────────────────────
# Register free at https://aisstream.io  (GitHub OAuth required to activate key)
AISSTREAM_API_KEY=

# Register free at https://www.aishub.net/join  (optional, adds corroboration)
AISHUB_API_KEY=

# Digitraffic Marine (Finland) — open data, no key needed.
# Set any identifying app name to enable (sent as Digitraffic-User header)
DIGITRAFFIC_USER=

# ─── Signing keys ────────────────────────────────────────────────────────────
# Generate with: node -e "const {generateKeypair} = await import('@maritime/core'); const k = generateKeypair(); console.log('EVT_SIGNING_KEY=' + k.privateKey); console.log('EVT_PUBLIC_KEY=' + k.publicKey)"
EVT_SIGNING_KEY=
EVT_PUBLIC_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maritime
DB_USER=maritime
DB_PASSWORD=maritime_dev

# ─── Blockchain anchoring ─────────────────────────────────────────────────────
# RPC endpoint — use Anvil locally, Base Sepolia for testnet
ANCHOR_RPC_URL=http://localhost:8545
# Ethereum private key for submitting anchor transactions.
# ⚠ The value below is Anvil's well-known dev key #0 — PUBLICLY KNOWN.
#   Only safe on a local Anvil node. Generate a fresh key before deploying to
#   any shared network (even a testnet), or anyone can anchor roots as owner.
ANCHOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# Set after running: pnpm deploy-anchor
MERKLE_ANCHOR_ADDRESS=

# ─── API server ──────────────────────────────────────────────────────────────
PORT=3000
# Secret for /admin/keys endpoint — generate with: openssl rand -hex 32
ADMIN_SECRET=

# ─── Webhooks (optional) ─────────────────────────────────────────────────────
WEBHOOK_URLS=
WEBHOOK_SECRET=
