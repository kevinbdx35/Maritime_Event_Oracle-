{
  "name": "maritime-event-oracle",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:core":     "pnpm --filter @maritime/core test",
    "test:api":      "pnpm --filter @maritime/api test",
    "test:ingestor": "pnpm --filter @maritime/ingestor test",
    "demo": "tsx scripts/demo.ts",
    "seed-db": "tsx scripts/seed-db.ts",
    "create-key": "tsx scripts/create-key.ts",
    "deploy-anchor": "tsx scripts/deploy-anchor.ts",
    "demo-oracle": "tsx --env-file=.env scripts/demo-oracle.ts",
    "db:up": "podman compose up -d",
    "db:down": "podman compose down",
    "db:migrate": "pnpm --filter @maritime/ingestor migrate",
    "start": "pm2 start pm2.config.cjs",
    "stop": "pm2 stop meo-api meo-ingestor meo-anchor-worker",
    "restart": "pm2 restart meo-api meo-ingestor meo-anchor-worker",
    "logs": "pm2 logs",
    "status": "pm2 status"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
